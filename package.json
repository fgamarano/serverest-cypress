{
  "name": "serverest-cypress-tests",
  "version": "1.0.0",
  "description": "Testes automatizados (E2E e API) para o ServeRest",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:frontend": "cypress run --spec \"cypress/e2e/frontend/**/*.cy.js\"",
    "cy:run:api": "cypress run --spec \"cypress/e2e/api/**/*.cy.js\"",
    "lint": "eslint cypress --ext .js",
    "format": "prettier --write \"cypress/**/*.js\""
  },
  "devDependencies": {
    "cypress": "^13.13.0",
    "eslint": "^8.57.0",
    "eslint-plugin-cypress": "^3.4.0",
    "prettier": "^3.3.2"
  }
}
